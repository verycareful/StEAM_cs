<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StEAM_.NET_main.ViewModels"
             xmlns:models="clr-namespace:StEAM_.NET_main.Models"
             x:Class="StEAM_.NET_main.Pages.NfcScanPage"
             x:DataType="vm:NfcScanViewModel"
             Title="NFC Scan"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <Shell.TitleView>
        <Label Text="NFC Scan" FontSize="20" FontAttributes="Bold"
               VerticalOptions="Center" TextColor="{StaticResource Primary}" />
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Mode Toggle -->
            <Frame BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                   CornerRadius="8" Padding="8" BorderColor="Transparent" HasShadow="True">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0" Text="Regular"
                            Command="{Binding SetModeCommand}" CommandParameter="Regular"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource OnPrimary}"
                            Opacity="{Binding IsRegularMode, Converter={StaticResource BoolToOpacityConverter}}"
                            CornerRadius="6" FontSize="13" />
                    <Button Grid.Column="1" Text="[T] Turbo"
                            Command="{Binding SetModeCommand}" CommandParameter="Turbo"
                            BackgroundColor="#C62828" TextColor="White"
                            FontAttributes="Bold"
                            Opacity="{Binding IsTurboMode, Converter={StaticResource BoolToOpacityConverter}}"
                            CornerRadius="6" FontSize="13" />
                </Grid>
            </Frame>

            <!-- Turbo Mode Warning Banner -->
            <Frame IsVisible="{Binding IsTurboMode}"
                   BackgroundColor="#FFEBEE"
                   CornerRadius="6" Padding="8" BorderColor="Transparent">
                <Label Text="TURBO — entries submitted instantly"
                       HorizontalTextAlignment="Center"
                       TextColor="#C62828"
                       FontAttributes="Bold" FontSize="13" />
            </Frame>

            <!-- NFC Status Banner -->
            <Frame IsVisible="{Binding IsNfcListening}"
                   BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                   CornerRadius="6" Padding="12" BorderColor="Transparent">
                <Label Text="{Binding NfcStatusText}"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource Primary}"
                       FontAttributes="Italic" />
            </Frame>

            <!-- NFC Not Enabled -->
            <Frame IsVisible="{Binding IsNfcEnabled, Converter={StaticResource InvertedBoolConverter}}" x:Name="NfcWarning"
                   BackgroundColor="#FFF3E0"
                   CornerRadius="6" Padding="12" BorderColor="Transparent">
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="NFC is disabled." VerticalOptions="Center" TextColor="#E65100" />
                    <Button Text="Enable NFC" Command="{Binding PromptNfcCommand}"
                            BackgroundColor="#E65100" TextColor="White"
                            CornerRadius="6" HeightRequest="36" FontSize="12" />
                </HorizontalStackLayout>
            </Frame>

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}" HorizontalOptions="Center" />

            <!-- Student Details -->
            <Frame IsVisible="{Binding HasStudent}"
                   BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                   CornerRadius="8" Padding="20" BorderColor="Transparent" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding StudentName}" FontSize="24" FontAttributes="Bold" />
                    <Label Text="{Binding StudentDepartment}" FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                    <Label Text="{Binding StudentCourse}" FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                    <Label Text="{Binding StudentSection}" FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                    <BoxView HeightRequest="1" Color="{StaticResource Primary}" Opacity="0.3" Margin="0,8" />
                    <Label Text="{Binding LateCountText}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Primary}" />

                    <Button Text="Submit Late Coming" Command="{Binding SubmitCommand}"
                            BackgroundColor="{StaticResource Primary}" TextColor="{StaticResource OnPrimary}"
                            FontAttributes="Bold" CornerRadius="8" HeightRequest="48" Margin="0,8,0,0" />
                </VerticalStackLayout>
            </Frame>

            <!-- Recent Entries -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding HasRecentEntries}">
                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                    <Label Text="Recent Entries" FontSize="18" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}" />
                    <Button Grid.Column="1" Text="Clear"
                            Command="{Binding ClearRecentEntriesCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Primary}"
                            FontSize="13" Padding="8,0" HeightRequest="32" />
                </Grid>

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecentEntries}" Spacing="6">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:RecentEntry">
                            <Frame BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                   CornerRadius="6" Padding="12" BorderColor="Transparent" HasShadow="False">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Text="{Binding StudentName}" FontSize="15" FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />
                                    <Frame Grid.Column="1" Grid.RowSpan="2"
                                           BackgroundColor="{Binding MethodColor}"
                                           CornerRadius="10" Padding="8,4" BorderColor="Transparent"
                                           HasShadow="False" VerticalOptions="Center">
                                        <Label Text="{Binding MethodLabel}" FontSize="11"
                                               TextColor="White" FontAttributes="Bold" />
                                    </Frame>
                                    <HorizontalStackLayout Grid.Row="1" Spacing="8">
                                        <Label Text="{Binding RegisterNumber}" FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                                        <Label Text="·" FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                                        <Label Text="{Binding TimeText}" FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
