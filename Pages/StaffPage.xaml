<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StEAM_.NET_main.ViewModels"
             x:Class="StEAM_.NET_main.Pages.StaffPage"
             x:DataType="vm:StaffViewModel"
             Title="Staff Dashboard"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="0,0,8,0">
            <Label Text="Staff Dashboard" FontSize="20" FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="{StaticResource Primary}" />
            <Button Grid.Column="1" Text="⚙"
                         Command="{Binding OpenSettingsCommand}"
                         BackgroundColor="Transparent"
                         TextColor="{StaticResource Primary}"
                         FontSize="22" Padding="0"
                         HeightRequest="36" WidthRequest="36"
                         VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="*,Auto">

        <!-- Tab Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Filters Section -->
                <Frame BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                       CornerRadius="8" Padding="16" BorderColor="Transparent" HasShadow="True">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Filters" FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" />

                        <Label Text="Start Date" FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                        <DatePicker Date="{Binding StartDate}" TextColor="{StaticResource Primary}" />

                        <Label Text="End Date" FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                        <DatePicker Date="{Binding EndDate}" TextColor="{StaticResource Primary}" />

                        <Label Text="Department" FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                        <Picker ItemsSource="{Binding Departments}"
                                SelectedItem="{Binding SelectedDepartment}" />

                        <Label Text="Course" FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                        <Picker ItemsSource="{Binding Courses}"
                                SelectedItem="{Binding SelectedCourse}" />

                        <Entry Placeholder="Batch (e.g. 2024)"
                               Text="{Binding FilterBatch}"
                               Keyboard="Numeric" />

                        <Entry Placeholder="Name"
                               Text="{Binding FilterName}" />

                        <Entry Placeholder="Register Number"
                               Text="{Binding FilterRegisterNumber}" />

                        <Entry Placeholder="Section (e.g. A)"
                               Text="{Binding FilterSection}"
                               MaxLength="1" />

                        <Button Text="Search"
                                Command="{Binding SearchCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="{StaticResource OnPrimary}"
                                FontAttributes="Bold"
                                CornerRadius="8"
                                HeightRequest="48" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Center" />

                <!-- Error -->
                <Label Text="{Binding ErrorMessage}"
                       TextColor="{StaticResource Error}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                       HorizontalTextAlignment="Center" />

                <!-- No Data -->
                <Frame IsVisible="{Binding HasData, Converter={StaticResource InvertedBoolConverter}}"
                       BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                       CornerRadius="8" Padding="16" BorderColor="Transparent">
                    <Label Text="No data matching filters. Try adjusting your search."
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                </Frame>

                <!-- Student View Section -->
                <Frame IsVisible="{Binding HasData}"
                       BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                       CornerRadius="8" Padding="16" BorderColor="Transparent" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="By Student" FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" />
                        <CollectionView ItemsSource="{Binding StudentGroupedData}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:StudentGroupItem">
                                    <VerticalStackLayout Padding="8" Spacing="4">
                                        <Label Text="{Binding Student.Name}" FontSize="18" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}" />
                                        <Label Text="{Binding Student.RegisterNumber}" FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
                                        <Label FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding TimesLate}" />
                                                    <Span Text=" times late" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <BoxView HeightRequest="1" Color="{StaticResource Primary}" Opacity="0.2" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Date View Section -->
                <Frame IsVisible="{Binding HasData}"
                       BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                       CornerRadius="8" Padding="16" BorderColor="Transparent" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="By Date" FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" />
                        <CollectionView ItemsSource="{Binding DateGroupedData}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:DateGroupItem">
                                    <VerticalStackLayout Padding="8" Spacing="4">
                                        <Label Text="{Binding Date, StringFormat='{0:yyyy-MM-dd}'}" FontSize="18" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}" />
                                        <Label FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding StudentsLate}" />
                                                    <Span Text=" students late" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <BoxView HeightRequest="1" Color="{StaticResource Primary}" Opacity="0.2" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
